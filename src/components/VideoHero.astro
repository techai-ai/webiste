---
interface Props {
  id?: string;
  src: string;
  poster?: string;
  heightClass?: string; // e.g., "h-[340px] md:h-[640px]"
  chipText?: string;
  title?: string;
  description?: string;
  primaryText?: string;
  primaryHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const {
  id = 'vh-' + Math.random().toString(36).slice(2, 8),
  src,
  poster,
  heightClass = 'h-[340px] md:h-[640px]',
  chipText,
  title,
  description,
  primaryText,
  primaryHref = '#',
  secondaryText,
  secondaryHref = '#',
} = Astro.props as Props;

// Using class + data-role selectors; no dynamic IDs required.
---
<div class="relative video-hero">
  <video
    src={src}
    playsinline
    preload="metadata"
    poster={poster}
    class={`w-full ${heightClass} object-cover`}
    onended="(function(v){var root=v.closest('.video-hero'); if(!root) return; var overlay=root.querySelector('[data-role=overlay]'); var mask=root.querySelector('[data-role=mask]'); try{ v.removeAttribute('controls'); v.pause(); v.currentTime=0; v.load(); }catch(e){} if(overlay){ overlay.style.display='flex'; } if(mask){ mask.style.display='block'; }})(this)"
  ></video>

  <div data-role="mask" class="absolute inset-0 bg-black/40 z-10"></div>

  <div data-role="overlay" class="absolute inset-0 z-20 flex flex-col items-center justify-center gap-6 px-4 text-center">
    {chipText && (
      <div class="inline-flex items-center gap-2 px-4 py-1 rounded-full border border-white/20 text-[12.9px] tracking-[0.25em] text-white/90 bg-white/5 backdrop-blur-sm">
        {chipText}
      </div>
    )}
    {title && (
      <h2 class="text-3xl md:text-5xl font-bold text-white drop-shadow-sm">{title}</h2>
    )}
    {description && (
      <p class="max-w-3xl text-gray-300 text-base md:text-lg leading-relaxed">{description}</p>
    )}

    <button
      type="button"
      class="w-16 h-16 md:w-20 md:h-20 rounded-full border border-white/20 bg-white/10 backdrop-blur-md flex items-center justify-center shadow-[0_0_0_6px_rgba(255,255,255,0.06),0_0_50px_rgba(37,99,235,0.35)] ring-1 ring-white/20 play-pulse hover:bg-white/15 transition"
      aria-label="Play video"
      onclick="(function(btn){var root=btn.closest('.video-hero'); if(!root) return; var v=root.querySelector('video'); var overlay=root.querySelector('[data-role=overlay]'); var mask=root.querySelector('[data-role=mask]'); try{ if(v){ var p=v.play&&v.play(); if(p&&p.then){ p.catch(function(){}) } v.setAttribute('controls',''); }}catch(e){} if(overlay) overlay.style.display='none'; if(mask) mask.style.display='none';})(this)"
    >
      <svg viewBox="0 0 24 24" class="w-8 h-8 md:w-10 md:h-10 text-white drop-shadow" fill="currentColor" aria-hidden="true">
        <path d="M8 5v14l11-7-11-7z"></path>
      </svg>
    </button>

    {(primaryText || secondaryText) && (
      <div class="flex items-center gap-4 mt-2">
        {primaryText && (
          <a href={primaryHref} class="px-6 py-3 rounded-full bg-amber-500 text-white font-semibold shadow hover:bg-amber-400 transition">
            {primaryText}
          </a>
        )}
        {secondaryText && (
          <a href={secondaryHref} class="px-6 py-3 rounded-full bg-white text-gray-900 font-semibold shadow hover:bg-gray-100 transition">
            {secondaryText}
          </a>
        )}
      </div>
    )}
  </div>
</div>
