---
import BaseLayout from "../layouts/BaseLayout.astro";
import ApplyForm from "../components/ApplyForm.astro";
---

<BaseLayout title="Contact Us | TechAI Inc">
  <section class="py-24 px-6 md:px-20 text-center relative overflow-hidden">
    <!-- Background Glow -->
    <div class="absolute inset-0 bg-gradient-to-b from-blue-800/10 via-violet-900/10 to-black/30 blur-3xl"></div>

    <div class="relative z-10 max-w-3xl mx-auto bg-transparent border border-transparent backdrop-blur-0 rounded-2xl p-10">
      <h1 class="text-4xl font-bold text-white mb-6 drop-shadow-[0_0_20px_rgba(37,99,235,0.3)]">Let's Connect</h1>
      <p class="text-gray-300 mb-10 text-lg">
        Have a project in mind or want to learn more about how AI can transform your business?
      </p>

      <!-- Contact Form -->
      <ApplyForm id="contactForm" idPrefix="c" includeJob={false} includeResume={false} submitLabel="Send Message" />
    </div>
  </section>

  <!-- Form logic handled inside ApplyForm component -->

</BaseLayout>

