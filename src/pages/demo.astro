---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Data Q&A Copilot Demo">
  <!-- global background removed; no-op -->

  <section class="py-24 px-6 md:px-20 text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-cyan-700/20 via-emerald-700/15 to-black/25 blur-3xl"></div>

    <div class="relative z-10 max-w-4xl mx-auto bg-transparent border border-transparent backdrop-blur-0 rounded-2xl p-10">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 drop-shadow-[0_0_20px_rgba(6,182,212,0.35)]">Data Q&A Copilot <span class="text-cyan-400">Demo</span></h1>
      <p class="text-gray-300 text-lg">Try a lightweight preview of our natural-language to SQL experience.</p>

      <div class="mt-10 text-left space-y-6">
        <div class="bg-[#0c1522]/80 border border-cyan-900/40 rounded-2xl p-6 shadow-[0_0_28px_rgba(6,182,212,0.18)] space-y-5">
          <h2 class="text-2xl font-bold text-white flex items-center gap-3"><span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-cyan-500/20 text-cyan-200 text-sm font-semibold">1</span>Natural Language Analytics on Any Data Source</h2>
          <div class="space-y-3 text-gray-300 leading-relaxed text-sm">
            <p><span class="font-semibold text-white">What it is:</span> Business users ask questions in plain English (“What were our top 10 products by margin last quarter in the US?”); the platform generates the right SQL, runs it, and returns answers, charts, and explanation.</p>
            <p><span class="font-semibold text-white">Why it matters:</span> Eliminates dependency on analysts, shortens decision cycles, and works across any cloud or database because everything is YAML-configured.</p>
            <p><span class="font-semibold text-white">Where to use it:</span> Executives, Sales, Marketing teams, Analysts, PMs, and ops teams who need self-service KPIs without learning SQL or BI tools.</p>
          </div>
        </div>

        <div class="bg-[#0c1522]/80 border border-cyan-900/40 rounded-2xl p-6 shadow-[0_0_28px_rgba(6,182,212,0.18)] space-y-5">
          <h2 class="text-2xl font-bold text-white flex items-center gap-3"><span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-cyan-500/20 text-cyan-200 text-sm font-semibold">2</span>SQL Co-Pilot for Data &amp; BI Teams</h2>
          <div class="space-y-3 text-gray-300 leading-relaxed text-sm">
            <p><span class="font-semibold text-white">What it is:</span> An AI SQL assistant built on Open_Data_QnA to help engineers and analysts write, optimize, and debug SQL across heterogeneous platforms.</p>
            <p><span class="font-semibold text-white">What it does:</span> Converts natural language to draft SQL, suggests joins/filters/aggregates, explains &amp; debugs queries, and adapts to multiple SQL dialects.</p>
            <p><span class="font-semibold text-white">Why it matters:</span> Gives sales and marketing teams instant insight into evolving trends while boosting both sales outcomes and analyst productivity.</p>
          </div>
        </div>

        <div class="bg-[#0c1522]/80 border border-cyan-900/40 rounded-2xl p-6 shadow-[0_0_28px_rgba(6,182,212,0.18)] space-y-5">
          <h2 class="text-2xl font-bold text-white flex items-center gap-3"><span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-cyan-500/20 text-cyan-200 text-sm font-semibold">3</span>Automated Data Catalog &amp; Schema Documentation</h2>
          <div class="space-y-3 text-gray-300 leading-relaxed text-sm">
            <p><span class="font-semibold text-white">What it is:</span> Use the LLM pipeline to generate human-readable table and column descriptions across all databases.</p>
            <p><span class="font-semibold text-white">What it does:</span> Reads schema/keys/sample data, generates business-friendly descriptions and tags, and outputs YAML/JSON for catalogs or Git.</p>
            <p><span class="font-semibold text-white">Why it matters:</span> Reduces manual documentation, clarifies “what’s in the data,” and keeps docs versioned as code.</p>
          </div>
        </div>

        <div class="bg-[#0c1522]/80 border border-cyan-900/40 rounded-2xl p-6 shadow-[0_0_28px_rgba(6,182,212,0.18)] space-y-5">
          <h2 class="text-2xl font-bold text-white flex items-center gap-3"><span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-cyan-500/20 text-cyan-200 text-sm font-semibold">4</span>Cross-System, Cross-Cloud Insights</h2>
          <div class="space-y-3 text-gray-300 leading-relaxed text-sm">
            <p><span class="font-semibold text-white">What it is:</span> A unified query experience across multiple databases and clouds without re-platforming.</p>
            <p><span class="font-semibold text-white">What it does:</span> Resolves which systems to hit, generates/executes per-source SQL, joins results at the platform layer, and returns a coherent answer.</p>
            <p><span class="font-semibold text-white">Why it matters:</span> Delivers “data fabric” style insights while keeping data in place; new systems are added via YAML configs.</p>
          </div>
        </div>

        <div class="bg-[#0c1522]/80 border border-cyan-900/40 rounded-2xl p-6 shadow-[0_0_28px_rgba(6,182,212,0.18)] space-y-5">
          <h2 class="text-2xl font-bold text-white flex items-center gap-3"><span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-cyan-500/20 text-cyan-200 text-sm font-semibold">5</span>Governed, Role-Aware Data Access via Chat</h2>
          <div class="space-y-3 text-gray-300 leading-relaxed text-sm">
            <p><span class="font-semibold text-white">What it is:</span> A governed analytics assistant that honors your identity/RBAC and DB security rules.</p>
            <p><span class="font-semibold text-white">What it does:</span> Integrates IAM/groups/RLS, ensures each user only sees permitted data, and generates policy-aware SQL from declarative configs.</p>
            <p><span class="font-semibold text-white">Why it matters:</span> Enables AI-powered analytics without bypassing compliance; policies live centrally in YAML.</p>
          </div>
        </div>

        <div class="bg-[#0c1522]/80 border border-cyan-900/40 rounded-2xl p-6 shadow-[0_0_28px_rgba(6,182,212,0.18)] space-y-5">
          <h2 class="text-2xl font-bold text-white flex items-center gap-3"><span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-cyan-500/20 text-cyan-200 text-sm font-semibold">6</span>Embedded “Ask Your Data” Widget</h2>
          <div class="space-y-3 text-gray-300 leading-relaxed text-sm">
            <p><span class="font-semibold text-white">What it is:</span> Embed Open_Data_QnA as a chat widget inside internal portals, CRM, ERP, or custom apps.</p>
            <p><span class="font-semibold text-white">What it does:</span> Context-aware questions (“Show last 6 months’ tickets for this customer”) with the same multi-cloud backend in a lightweight UI.</p>
            <p><span class="font-semibold text-white">Why it matters:</span> Puts analytics where people work, improving adoption and creating a consistent AI layer across apps.</p>
          </div>
        </div>

        <div class="bg-[#0c1522]/80 border border-cyan-900/40 rounded-2xl p-6 shadow-[0_0_28px_rgba(6,182,212,0.18)] space-y-5">
          <h2 class="text-2xl font-bold text-white flex items-center gap-3"><span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-cyan-500/20 text-cyan-200 text-sm font-semibold">7</span>Data Onboarding &amp; Migration Assistant</h2>
          <div class="space-y-3 text-gray-300 leading-relaxed text-sm">
            <p><span class="font-semibold text-white">What it is:</span> An AI assistant for profiling, validating, and comparing datasets during migrations.</p>
            <p><span class="font-semibold text-white">What it does:</span> Auto-generates profiling queries, compares source vs. target, and produces human-readable summaries of anomalies.</p>
            <p><span class="font-semibold text-white">Why it matters:</span> Speeds migrations, reduces manual reconciliation, and gives PMs clear quality summaries.</p>
          </div>
        </div>

        <div class="bg-[#0c1522]/80 border border-cyan-900/40 rounded-2xl p-6 shadow-[0_0_28px_rgba(6,182,212,0.18)] space-y-5">
          <h2 class="text-2xl font-bold text-white flex items-center gap-3"><span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-cyan-500/20 text-cyan-200 text-sm font-semibold">8</span>Industry-Specific Q&amp;A on Operational Data</h2>
          <div class="space-y-3 text-gray-300 leading-relaxed text-sm">
            <p class="text-white font-semibold">Examples:</p>
            <ul class="list-disc list-inside space-y-1">
              <li class="text-gray-300">Travel/Transportation: “How many moves by city, truck size, and day of week last quarter?”</li>
              <li class="text-gray-300">Finance/Insurance: “Show net revenue, loss ratio, and claim frequency by product line and region.”</li>
              <li class="text-gray-300">Healthcare/Life Sciences: “Count patients by cohort, treatment arm, and visit schedule.”</li>
            </ul>
            <p><span class="font-semibold text-white">Why it matters:</span> Vertical-ready through YAML configs for data sources, LLMs, and SQL dialects — the platform stays the same.</p>
          </div>
        </div>

        <div class="bg-[#0c1522]/80 border border-cyan-900/40 rounded-2xl p-6 shadow-[0_0_28px_rgba(6,182,212,0.18)] space-y-3">
          <h2 class="text-2xl font-bold text-white flex items-center gap-3"><span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-cyan-500/20 text-cyan-200 text-sm font-semibold">9</span>One-Slide Summary</h2>
          <p class="text-gray-300 text-sm leading-relaxed">Open Data QnA Platform (Powered by Google and elevated by TechAI): a configurable, multi-cloud, multi-LLM analytics assistant letting users ask in natural language and get trusted answers directly from databases. Works with any cloud/DB via YAML, supports business users and technical teams, and is built on Open_Data_QnA with enterprise-grade governance and future-ready LLM/embedding choices.</p>
        </div>
      </div>
      
      <div class="mt-10 bg-black/70 border border-white/10 rounded-2xl p-6 md:p-8 shadow-[0_0_40px_rgba(0,0,0,0.35)] grid md:grid-cols-2 gap-8 text-left">
        <div class="space-y-5">
          <p class="text-cyan-200 font-semibold tracking-wide uppercase text-xs">Built on Open_Data_QnA + Vertex AI, deployed securely in your cloud.</p>
          <div class="grid grid-cols-1 gap-4">
            <div class="h-full bg-[#0d1320] border border-cyan-900/40 rounded-xl p-4 shadow-[0_0_20px_rgba(6,182,212,0.15)]">
              <div class="flex items-center gap-2 mb-2 text-cyan-200 text-xs font-semibold">01<span class="h-[1px] flex-1 bg-cyan-900/60"></span></div>
              <div class="font-semibold text-white mb-1">Ask in English, answer from SQL</div>
              <p class="text-gray-400 text-sm">Business users ask “What was our 2024 revenue by region and product?” and get accurate answers plus the exact SQL that ran on BigQuery / your DB.</p>
            </div>
            <div class="h-full bg-[#0d1320] border border-cyan-900/40 rounded-xl p-4 shadow-[0_0_20px_rgba(6,182,212,0.15)]">
              <div class="flex items-center gap-2 mb-2 text-cyan-200 text-xs font-semibold">02<span class="h-[1px] flex-1 bg-cyan-900/60"></span></div>
              <div class="font-semibold text-white mb-1">Secure, explainable, in your environment</div>
              <p class="text-gray-400 text-sm">Runs inside your GCP/AWS/Azure account, honoring IAM, VPC, and data permissions. Every answer shows the generated SQL, tables used, and optional sample rows.</p>
            </div>
            <div class="h-full bg-[#0d1320] border border-cyan-900/40 rounded-xl p-4 shadow-[0_0_20px_rgba(6,182,212,0.15)]">
              <div class="flex items-center gap-2 mb-2 text-cyan-200 text-xs font-semibold">03<span class="h-[1px] flex-1 bg-cyan-900/60"></span></div>
              <div class="font-semibold text-white mb-1">Domain-tuned for your business</div>
              <p class="text-gray-400 text-sm">We map your real metrics (MRR, churn, ARPU, shipment delays, claims, etc.) to underlying tables, and tune prompts &amp; logic for your industry (Finance, Travel, Logistics, Healthcare…).</p>
            </div>
            <div class="h-full bg-[#0d1320] border border-cyan-900/40 rounded-xl p-4 shadow-[0_0_20px_rgba(6,182,212,0.15)]">
              <div class="flex items-center gap-2 mb-2 text-cyan-200 text-xs font-semibold">04<span class="h-[1px] flex-1 bg-cyan-900/60"></span></div>
              <div class="font-semibold text-white mb-1">From pilot to production in weeks</div>
              <p class="text-gray-400 text-sm">Start with 1–2 critical datasets and 10–20 key questions, then roll out with SSO, RBAC, monitoring, and ongoing SQL quality evaluation.</p>
            </div>
          </div>
        </div>

        <div class="bg-[#0b111d] border border-cyan-900/40 rounded-xl p-6 shadow-[0_0_30px_rgba(37,99,235,0.2)] flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <div class="h-10 w-10 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center text-white font-bold">TAI</div>
            <div class="text-left">
            <div class="text-white font-semibold">Data Q&A Copilot</div>
              <div class="text-gray-400 text-sm">High-level architecture</div>
            </div>
          </div>
          <div class="flex items-center justify-between gap-2 text-sm text-white">
            <div class="flex-1 text-center bg-white/5 border border-white/10 rounded-lg py-3 px-2">Users</div>
            <div class="text-cyan-300">→</div>
            <div class="flex-1 text-center bg-white/5 border border-cyan-800/50 rounded-lg py-3 px-2">Q&amp;A Engine</div>
            <div class="text-cyan-300">→</div>
            <div class="flex-1 text-center bg-white/5 border border-cyan-800/50 rounded-lg py-3 px-2">Data Warehouse</div>
          </div>
          <p class="text-gray-300 text-sm leading-relaxed">Users ask questions via web, chat, or MCP-integrated tools; TechAI Data Q&amp;A Copilot generates and validates SQL via Open_Data_QnA, executes it on your warehouse, and returns governed, explainable answers.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6 md:px-20">
    <div class="max-w-6xl mx-auto bg-transparent border border-cyan-900/40 rounded-2xl p-8 shadow-[0_0_25px_rgba(6,182,212,0.25)]">
      <h2 class="text-2xl font-bold text-white mb-4">Preview</h2>

      <div class="mb-6">
        <div class="bg-transparent border border-cyan-900/40 rounded-xl p-4">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-white font-semibold">History</h3>
            <button id="clear-saved" class="text-xs text-cyan-200 hover:underline">Clear</button>
          </div>
          <div id="saved-list" class="space-y-2 max-h-[20rem] overflow-y-auto">
            <p class="text-gray-400 text-sm">No saved queries yet.</p>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6 text-left">
        <div>
          <label for="nlq" class="block text-gray-300 mb-2 font-medium">Your question</label>
          <div class="flex flex-col gap-3">
            <div class="flex flex-wrap gap-2">
              <button class="sample-chip px-3 py-1.5 rounded-full bg-cyan-900/30 text-cyan-200 border border-cyan-800/50 hover:bg-cyan-800/40 transition" data-sample="total revenue by month for 2024">Revenue by month</button>
              <button class="sample-chip px-3 py-1.5 rounded-full bg-cyan-900/30 text-cyan-200 border border-cyan-800/50 hover:bg-cyan-800/40 transition" data-sample="count orders last 30 days">Orders last 30 days</button>
              <button class="sample-chip px-3 py-1.5 rounded-full bg-cyan-900/30 text-cyan-200 border border-cyan-800/50 hover:bg-cyan-800/40 transition" data-sample="average sales by week for 2023">Avg sales by week</button>
            </div>
            <textarea id="nlq" rows="6" placeholder="e.g., total revenue by month for 2024" class="w-full px-4 py-3 rounded-md bg-[#0c1520] border border-cyan-900/40 focus:border-cyan-500 focus:ring-2 focus:ring-cyan-700 outline-none text-white placeholder-gray-400 transition resize-none"></textarea>
            <div class="flex items-center gap-3">
              <button id="gen" class="btn-glow btn-glow-sm">Generate</button>
              <button id="save" class="px-3 py-1.5 rounded-md border border-cyan-900/40 text-gray-200 hover:bg-cyan-900/30">Save</button>
              <p class="text-xs text-gray-400">Client-only mock — no network requests.</p>
            </div>
          </div>
        </div>
        <div>
          <div class="space-y-4">
            <div>
              <label for="answer" class="block text-gray-300 mb-2 font-medium">Response</label>
              <textarea id="answer" rows="12" readonly class="w-full px-4 py-3 rounded-md bg-[#081018] border border-cyan-900/40 text-gray-200 resize-none"></textarea>
            </div>
            <div>
              <button id="toggle-sql" class="px-3 py-1.5 rounded-md border border-cyan-900/40 text-gray-200 hover:bg-cyan-900/30">Show SQL</button>
            </div>
            <div id="sql-container" class="hidden">
              <label for="sql" class="block text-gray-300 mb-2 font-medium">Generated SQL</label>
              <textarea id="sql" rows="12" readonly class="w-full px-4 py-3 rounded-md bg-[#081018] border border-cyan-900/40 text-gray-200 resize-none"></textarea>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function(){
      const btn = document.getElementById('gen');
      if (!btn) return;
      const nlq = document.getElementById('nlq');
      const sql = document.getElementById('sql');

      function normalize(s){ return (s || '').toLowerCase(); }
      function contains(s, arr){ s = normalize(s); return arr.some(k => s.includes(k)); }

      function generateMockSql(question){
        const q = question.trim();
        if (!q) return { sql: '/* enter a question above */', meta: { table: '', metricAlias: '', timeAlias: '' } };

        const nq = normalize(q);
        let table = '`demo.transactions`';
        let metricExpr = 'SUM(amount)';
        let metricAlias = 'total_revenue';

        if (contains(nq, ['order','orders'])) {
          table = '`demo.orders`';
          metricExpr = contains(nq, ['avg','average']) ? 'AVG(total_amount)' : contains(nq, ['sum','revenue','sales']) ? 'SUM(total_amount)' : 'COUNT(*)';
          metricAlias = metricExpr.startsWith('COUNT') ? 'order_count' : 'total_sales';
        } else if (contains(nq, ['user','customer'])) {
          table = '`demo.users`';
          metricExpr = 'COUNT(*)';
          metricAlias = 'user_count';
        } else if (contains(nq, ['revenue','sales'])) {
          table = '`demo.transactions`';
          metricExpr = contains(nq, ['avg','average']) ? 'AVG(amount)' : 'SUM(amount)';
          metricAlias = metricExpr.startsWith('AVG') ? 'avg_revenue' : 'total_revenue';
        }

        let timeExpr = 'DATE(created_at)';
        let timeAlias = 'day';
        if (contains(nq, ['month'])) { timeExpr = 'DATE_TRUNC(DATE(created_at), MONTH)'; timeAlias = 'month'; }
        else if (contains(nq, ['year'])) { timeExpr = 'DATE_TRUNC(DATE(created_at), YEAR)'; timeAlias = 'year'; }
        else if (contains(nq, ['week'])) { timeExpr = 'DATE_TRUNC(DATE(created_at), WEEK)'; timeAlias = 'week'; }

        const whereParts = [];
        const yearMatch = nq.match(/20\d{2}/);
        if (yearMatch) whereParts.push(`EXTRACT(YEAR FROM DATE(created_at)) = ${yearMatch[0]}`);
        if (contains(nq, ['last 30 days','past 30 days'])) whereParts.push('DATE(created_at) >= DATE_SUB(CURRENT_DATE(), INTERVAL 30 DAY)');
        if (contains(nq, ['last 7 days','past 7 days'])) whereParts.push('DATE(created_at) >= DATE_SUB(CURRENT_DATE(), INTERVAL 7 DAY)');

        const whereClause = whereParts.length ? `\nWHERE ${whereParts.join(' AND ')}` : '';
        const groupOrder = `\nGROUP BY ${timeAlias}\nORDER BY ${timeAlias}`;
        const sql = `/* demo: intent -> ${q.replace(/\*\//g,'*\/')} */\n\nSELECT\n  ${timeExpr} AS ${timeAlias},\n  ${metricExpr} AS ${metricAlias}\nFROM ${table}${whereClause}${groupOrder};`;
        return { sql, meta: { table, metricExpr, metricAlias, timeExpr, timeAlias, where: whereClause } };
      }

      function seededRand(seed){ let x = Math.imul(9301, seed) + 49297; return () => { x = (Math.imul(x,1103515245)+12345) & 0x7fffffff; return (x % 10000) / 10000; }; }
      function generateMockAnswer(question, meta){
        const seed = Array.from(question).reduce((a,c)=>a + c.charCodeAt(0), 0) || 1;
        const rand = seededRand(seed);
        const grain = meta.timeAlias || 'period';
        const metric = meta.metricAlias || 'value';
        const buckets = grain === 'month' ? 6 : grain === 'week' ? 4 : grain === 'year' ? 3 : 7;
        const samples = Array.from({length: buckets}, (_,i)=> Math.round((rand()*0.6+0.2)*1000)*10);
        const total = samples.reduce((a,b)=>a+b,0);
        const label = grain.charAt(0).toUpperCase()+grain.slice(1);
        const example = samples.slice(0, Math.min(3, samples.length)).map((v,i)=>`${label} ${i+1}: ${v.toLocaleString()}`).join(', ');
        return `Estimated ${metric.replace(/_/g,' ')} by ${grain}: ${example}.\nApproximate total: ${total.toLocaleString()}.\n(Note: simulated demo answer based on your question and generated SQL.)`;
      }

      function generate(){
        const q = (nlq.value || '').trim();
        const result = generateMockSql(q);
        sql.value = result.sql;
        const ans = document.getElementById('answer');
        if (ans) ans.value = generateMockAnswer(q, result.meta);
        const sqlWrap = document.getElementById('sql-container');
        const toggle = document.getElementById('toggle-sql');
        if (sqlWrap) sqlWrap.classList.add('hidden');
        if (toggle) toggle.textContent = 'Show SQL';
      }

      btn.addEventListener('click', generate);
      document.querySelectorAll('.sample-chip').forEach(el => el.addEventListener('click', () => { const s = el.getAttribute('data-sample') || ''; nlq.value = s; generate(); }));

      // SQL toggle
      (function(){
        const sqlWrap = document.getElementById('sql-container');
        const toggle = document.getElementById('toggle-sql');
        function setLabel(){ if (toggle && sqlWrap) toggle.textContent = sqlWrap.classList.contains('hidden') ? 'Show SQL' : 'Hide SQL'; }
        toggle && toggle.addEventListener('click', () => { if (!sqlWrap) return; sqlWrap.classList.toggle('hidden'); setLabel(); });
        setLabel();
      })();

      // Saved queries sidebar
      const saveBtn = document.getElementById('save');
      const savedList = document.getElementById('saved-list');
      const clearSaved = document.getElementById('clear-saved');
      function getSaved(){ try { return JSON.parse(localStorage.getItem('demoSavedQueries') || '[]'); } catch { return []; } }
      function setSaved(list){ localStorage.setItem('demoSavedQueries', JSON.stringify(list)); }
      function renderSaved(){ const list = getSaved(); if (!savedList) return; if (!list.length){ savedList.innerHTML = '<p class="text-gray-400 text-sm">No saved queries yet.</p>'; return; } savedList.innerHTML = list.map(item => `
          <div class="group border border-cyan-900/40 rounded-md p-3 bg-[#0c1520] hover:bg-[#102030] transition" data-id="${item.id}">
            <div class="flex items-center justify-between">
              <button class="text-left text-gray-200 hover:text-white truncate" data-action="load" title="${item.question}">${item.question}</button>
              <button class="text-xs text-gray-400 hover:text-red-300" data-action="delete">Delete</button>
            </div>
            <div class="text-[11px] text-gray-500 mt-1">${new Date(item.ts).toLocaleString()}</div>
          </div>`).join(''); }
      function saveCurrent(){ const q = (nlq.value || '').trim(); if (!q || !sql.value) return; const list = getSaved(); const id = Date.now().toString(36)+Math.random().toString(36).slice(2,6); const entry = { id, question: q, sql: sql.value, answer: (document.getElementById('answer')||{}).value || '', meta: {}, ts: Date.now() }; list.unshift(entry); setSaved(list.slice(0,50)); renderSaved(); }
      function loadSaved(id){ const list = getSaved(); const item = list.find(x => x.id === id); if (!item) return; nlq.value = item.question; sql.value = item.sql; const ans = document.getElementById('answer'); if (ans) ans.value = item.answer || ''; }
      savedList && savedList.addEventListener('click', (e) => { const target = e.target; if (!(target instanceof Element)) return; const wrap = target.closest('[data-id]'); const id = wrap && wrap.getAttribute('data-id'); if (!id) return; const action = target.getAttribute('data-action'); if (action === 'delete'){ const list = getSaved().filter(x => x.id !== id); setSaved(list); renderSaved(); } else { loadSaved(id); } });
      saveBtn && saveBtn.addEventListener('click', saveCurrent);
      clearSaved && clearSaved.addEventListener('click', () => { setSaved([]); renderSaved(); });
      renderSaved();
    })();
  </script>

</BaseLayout>
