---
import BaseLayout from "../layouts/BaseLayout.astro";
import VideoHero from "../components/VideoHero.astro";
---
<BaseLayout title="TechAI Inc | Empowering Businesses with AI" compactFooter={true}>
  <div class="relative overflow-hidden">
  <!-- 🌌 HERO SECTION -->
  <section class="flex items-start justify-center px-6 md:px-20 pt-12 md:pt-16 pb-20 min-h-[60vh]">
    <div class="text-center space-y-8 max-w-[900px] mx-auto">
      <div id="heroWelcome" class="hero-reveal inline-flex items-center gap-2 px-4 py-1 rounded-full border border-white/20 text-[12.9px] tracking-[0.25em] text-white/80 bg-white/5 backdrop-blur-sm mx-auto" style="--reveal-delay: 0ms;">
        WELCOME TO TECH AI
      </div>

      <h1 id="heroTitle" class="font-extrabold text-2xl md:text-4xl text-white tracking-tight leading-tight">
        <span
          id="heroTypewriterLead"
          class="typewriter-line"
          data-text="AI-Driven. "
        >
          AI-Driven.
        </span>
        <span
          id="heroTypewriterAccent"
          class="typewriter-line text-blue-400"
          data-text="Tech-Enhanced."
        >
          Tech-Enhanced.
        </span>
      </h1>

      <p id="heroBody" class="text-left text-gray-300 text-base md:text-lg leading-relaxed max-w-[900px] mx-auto font-medium px-4 md:px-0">
        <span id="heroBodyType">
          <span class="hero-body-seg float-left text-white/80 text-5xl md:text-6xl font-light leading-[0.85] mr-2.5 mt-0.5 md:mt-1 drop-shadow-[0_1px_2px_rgba(0,0,0,0.25)]">L</span><span class="hero-body-seg">everaging AI tools and technologies for demand forecasting, inventory optimization, cost reduction and driving business growth. We deliver cutting-edge solutions tailored to your unique needs.</span><br /><span class="hero-body-seg">At TechAI, we help organizations unlock the power of Artificial Intelligence across leading enterprise ERP and CRM platforms such as </span><span class="hero-body-seg text-blue-300">Salesforce, NetSuite, SAP, and Oracle</span><span class="hero-body-seg">. By integrating AI-driven intelligence into core business systems, companies can automate operations, improve forecasting, enhance customer engagement, and make data-driven decisions in real time.</span>
        </span>
      </p>
      
    </div>

    
  </section>


  


  

  

  <!-- ⚡ CAPABILITIES SECTION -->
  <section id="servicesSection" class="py-16 px-6 md:px-20">
    <div class="flex justify-center mb-12">
      <div class="scroll-reveal inline-flex items-center gap-2 px-4 py-1 rounded-full border border-white/20 text-[12.9px] tracking-[0.25em] text-white/80 bg-white/5 backdrop-blur-sm" style="--reveal-delay: 0ms;">
        OUR SERVICES
      </div>
    </div>
    <div class="services-content">
    <div class="ai-tiles ai-tiles-deck">
      <!-- Tile: Text-to-SQL -->
      <a href="/demo" class="service-carousel-item scroll-reveal tile group p-6 min-h-[420px] flex flex-col justify-between" style="--reveal-delay: 70ms;">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-full p-[2px] bg-gradient-to-br from-blue-500 to-violet-500">
            <div class="w-full h-full rounded-full bg-[#0b0d1f] flex items-center justify-center text-blue-300">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 5h16M4 12h16M4 19h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
          <div>
            <h3 class="tile-title text-white font-semibold">Data Q&A Copilot</h3>
            <p class="text-gray-300 text-sm mt-1 leading-relaxed">Convert plain English to optimized, safe SQL with schema learning.</p>
            <div class="tile-cta mt-3 hidden group-hover:flex justify-end">
              <span class="btn-glow btn-glow-sm inline-block">Explore</span>
            </div>
            <img src="/text2sql_tile1.png" alt="Text-to-SQL tile visual" class="mt-6 w-[115%] sm:w-[120%] -ml-3 sm:-ml-6 object-contain object-center rounded-md border border-white/10 bg-[#0b0d1f] select-none" />
          </div>
        </div>
      </a>

      <!-- Tile: RAG Chatbots -->
      <a href="#" class="service-carousel-item scroll-reveal tile group p-6 min-h-[220px] flex flex-col justify-between" style="--reveal-delay: 130ms;">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-full p-[2px] bg-gradient-to-br from-violet-500 to-fuchsia-500">
            <div class="w-full h-full rounded-full bg-[#0b0d1f] flex items-center justify-center text-violet-300">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 3a9 9 0 100 18 9 9 0 000-18zm-3 9h6m-4 3h2m-5-6h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
          <div>
            <h3 class="tile-title text-white font-semibold">RAG Knowledge Chatbots</h3>
            <p class="text-gray-300 text-sm mt-1">Empower enterprise data with natural Q&amp;A over your docs.</p>
            <div class="tile-cta mt-3 hidden group-hover:flex justify-end">
              <span class="btn-glow btn-glow-sm inline-block">Explore</span>
            </div>
            <img src="/RAG-knowledgebase-bot.png" alt="RAG Knowledge Chatbots visual" class="mt-6 w-[115%] sm:w-[120%] -ml-3 sm:-ml-6 object-contain object-center rounded-md border border-white/10 bg-[#0b0d1f] select-none" />
          </div>
        </div>
      </a>

      <!-- Tile: Predictive Insights -->
      <a href="#" class="service-carousel-item scroll-reveal tile group p-6 min-h-[220px] flex flex-col justify-between" style="--reveal-delay: 190ms;">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-full p-[2px] bg-gradient-to-br from-cyan-500 to-blue-500">
            <div class="w-full h-full rounded-full bg-[#0b0d1f] flex items-center justify-center text-cyan-300">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 17l4-5 4 3 6-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
          <div>
            <h3 class="tile-title text-white font-semibold">Predictive Insights Engine</h3>
            <p class="text-gray-300 text-sm mt-1">Forecast trends using ML pipelines and real-time data.</p>
            <div class="tile-cta mt-3 hidden group-hover:flex justify-end">
              <span class="btn-glow btn-glow-sm inline-block">Explore</span>
            </div>
            <img src="/predictive-insights-engine.png" alt="Predictive Insights Engine visual" class="mt-6 w-[115%] sm:w-[120%] -ml-3 sm:-ml-6 object-contain object-center rounded-md border border-white/10 bg-[#0b0d1f] select-none" />
          </div>
        </div>
      </a>

      <!-- Tile: AI Infra -->
      <a href="#" class="service-carousel-item scroll-reveal tile group p-6 min-h-[220px] flex flex-col justify-between" style="--reveal-delay: 250ms;">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-full p-[2px] bg-gradient-to-br from-indigo-500 to-blue-500">
            <div class="w-full h-full rounded-full bg-[#0b0d1f] flex items-center justify-center text-indigo-300">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
          <div>
            <h3 class="tile-title text-white font-semibold">AI Infrastructure on Cloud</h3>
            <p class="text-gray-300 text-sm mt-1">Deploy LLMs on AWS, GCP, or Azure with best practices.</p>
            <div class="tile-cta mt-3 hidden group-hover:flex justify-end">
              <span class="btn-glow btn-glow-sm inline-block">Explore</span>
            </div>
            <img src="/AI-Infra-on-cloud.png" alt="AI Infrastructure on Cloud visual" class="mt-6 w-[115%] sm:w-[120%] -ml-3 sm:-ml-6 object-contain object-center rounded-md border border-white/10 bg-[#0b0d1f] select-none" />
          </div>
        </div>
      </a>

      <!-- Tile: AI Ops Automation -->
      <a href="#" class="service-carousel-item scroll-reveal tile group p-6 min-h-[420px] flex flex-col justify-between" style="--reveal-delay: 310ms;">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-full p-[2px] bg-gradient-to-br from-purple-500 to-pink-500">
            <div class="w-full h-full rounded-full bg-[#0b0d1f] flex items-center justify-center text-pink-300">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 3v6m0 6v6M3 12h6m6 0h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
          <div>
            <h3 class="tile-title text-white font-semibold">AI Ops Automation</h3>
            <p class="text-gray-300 text-sm mt-1">Monitor, retrain, and version models with automated workflows.</p>
            <div class="tile-cta mt-3 hidden group-hover:flex justify-end">
              <span class="btn-glow btn-glow-sm inline-block">Explore</span>
            </div>
            <img src="/aiops.png" alt="AI Ops Automation visual" class="mt-6 w-[115%] sm:w-[120%] -ml-3 sm:-ml-6 object-contain object-center rounded-md border border-white/10 bg-[#0b0d1f] select-none" />
          </div>
        </div>
      </a>

      <!-- Tile: Dynamic Pricing -->
      <a href="#" class="service-carousel-item scroll-reveal tile group p-6 min-h-[220px] flex flex-col justify-between" style="--reveal-delay: 370ms;">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-full p-[2px] bg-gradient-to-br from-emerald-500 to-teal-500">
            <div class="w-full h-full rounded-full bg-[#0b0d1f] flex items-center justify-center text-emerald-300">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M7 10l3 3 7-7M3 21h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
          <div>
            <h3 class="tile-title text-white font-semibold">Dynamic Pricing Models</h3>
            <p class="text-gray-300 text-sm mt-1">Optimize pricing with demand-aware ML and A/B testing.</p>
            <div class="tile-cta mt-3 hidden group-hover:flex justify-end">
              <span class="btn-glow btn-glow-sm inline-block">Explore</span>
            </div>
            <img src="/optimal-price.png" alt="Dynamic Pricing Models visual" class="mt-6 w-[115%] sm:w-[120%] -ml-3 sm:-ml-6 object-contain object-center rounded-md border border-white/10 bg-[#0b0d1f] select-none" />
          </div>
        </div>
      </a>

      <!-- Tile: Research & Development -->
      <a href="#" class="service-carousel-item scroll-reveal tile group p-6 min-h-[420px] flex flex-col justify-between" style="--reveal-delay: 430ms;">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-full p-[2px] bg-gradient-to-br from-sky-500 to-indigo-500">
            <div class="w-full h-full rounded-full bg-[#0b0d1f] flex items-center justify-center text-sky-300">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 3h12M9 3l.01 6.5a2 2 0 0 1-.39 1.19L6.7 14.2A4 4 0 0 0 10 20h4a4 4 0 0 0 3.3-5.8l-1.92-3.51a2 2 0 0 1-.24-.94V3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
          <div>
            <h3 class="tile-title text-white font-semibold">Research &amp; Development</h3>
            <p class="text-gray-300 text-sm mt-1">Prototype new AI ideas, evaluate models, and validate POCs fast.</p>
            <div class="tile-cta mt-3 hidden group-hover:flex justify-end">
              <span class="btn-glow btn-glow-sm inline-block">Explore</span>
            </div>
            <img src="/research.png" alt="Research & Development visual" class="mt-6 w-[115%] sm:w-[120%] -ml-3 sm:-ml-6 object-contain object-center rounded-md border border-white/10 bg-[#0b0d1f] select-none" />
          </div>
        </div>
      </a>

      <!-- Tile: Computer Vision Systems -->
      <a href="#" class="service-carousel-item scroll-reveal tile group p-6 min-h-[220px] flex flex-col justify-between" style="--reveal-delay: 490ms;">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 rounded-full p-[2px] bg-gradient-to-br from-amber-500 to-rose-500">
            <div class="w-full h-full rounded-full bg-[#0b0d1f] flex items-center justify-center text-amber-300">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 5c4.5 0 8 3.5 9.5 6-1.5 2.5-5 6-9.5 6S4 13.5 2.5 11C4 8.5 7.5 5 12 5zm0 3.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
          <div>
            <h3 class="tile-title text-white font-semibold">Computer Vision Systems</h3>
            <p class="text-gray-300 text-sm mt-1">Detect, track, and classify with robust, real-time vision models.</p>
            <div class="tile-cta mt-3 hidden group-hover:flex justify-end">
              <span class="btn-glow btn-glow-sm inline-block">Explore</span>
            </div>
            <img src="/computer-vision.png" alt="Computer Vision Systems visual" class="mt-6 w-[115%] sm:w-[120%] -ml-3 sm:-ml-6 object-contain object-center rounded-md border border-white/10 bg-[#0b0d1f] select-none" />
          </div>
        </div>
      </a>

      <button id="servicesNextBtn" class="services-next-btn" type="button" aria-label="Next service tile">
        <span aria-hidden="true">-></span>
      </button>
    </div>
    <aside class="scroll-reveal service-info-box" style="--reveal-delay: 180ms;">
      <div class="service-info-scroll">
      <h3 class="text-white text-2xl md:text-3xl font-semibold leading-tight">AI for <span class="text-blue-300">Salesforce</span></h3>
      <p class="mt-5 text-gray-300 leading-relaxed">
        Salesforce is one of the leading CRM platforms used by enterprises to manage customer relationships, sales pipelines, and marketing campaigns. TechAI enhances Salesforce capabilities with AI-powered automation and predictive insights.
      </p>
      <p class="mt-4 text-gray-300 leading-relaxed">
        AI capabilities we implement with Salesforce include predictive lead scoring to identify high-value prospects, intelligent chatbots for customer engagement, automated case classification and resolution, sales forecasting models based on historical data, and generative AI tools that help sales teams generate emails, proposals, and responses automatically.
      </p>
      <p class="mt-4 text-gray-300 leading-relaxed">
        We also integrate AI models with Salesforce data to enable real-time analytics dashboards, recommendation systems for upselling and cross-selling, and intelligent customer sentiment analysis.
      </p>

      <h3 class="mt-10 text-white text-2xl md:text-3xl font-semibold leading-tight">AI for <span class="text-blue-300">NetSuite ERP</span></h3>
      <p class="mt-5 text-gray-300 leading-relaxed">
        NetSuite is widely used for financial management, order management, inventory tracking, and business operations. TechAI integrates AI and machine learning to improve operational efficiency and financial forecasting.
      </p>
      <p class="mt-4 text-gray-300 leading-relaxed">
        Our AI-powered NetSuite solutions include demand forecasting for inventory optimization, automated financial anomaly detection, intelligent invoice processing, AI-driven supply chain optimization, and predictive revenue forecasting.
      </p>
      <p class="mt-4 text-gray-300 leading-relaxed">
        By combining machine learning models with NetSuite data pipelines, organizations can automate routine financial processes, reduce operational risks, and gain predictive insights into business performance.
      </p>

      <h3 class="mt-10 text-white text-2xl md:text-3xl font-semibold leading-tight">AI for <span class="text-blue-300">SAP Systems</span></h3>
      <p class="mt-5 text-gray-300 leading-relaxed">
        SAP powers mission-critical operations for many large enterprises across manufacturing, logistics, finance, and supply chain management. TechAI integrates advanced AI capabilities with SAP environments to enable intelligent automation and predictive analytics.
      </p>
      <p class="mt-4 text-gray-300 leading-relaxed">
        Our SAP AI solutions include predictive maintenance for manufacturing equipment, supply chain optimization using machine learning, intelligent document processing for invoices and procurement documents, automated financial reconciliation, and AI-powered risk detection.
      </p>
      <p class="mt-4 text-gray-300 leading-relaxed">
        We also build generative AI assistants that allow employees to query SAP systems using natural language, making enterprise data easier to access and analyze.
      </p>

      <h3 class="mt-10 text-white text-2xl md:text-3xl font-semibold leading-tight">AI for <span class="text-blue-300">Oracle ERP</span></h3>
      <p class="mt-5 text-gray-300 leading-relaxed">
        Oracle ERP systems manage enterprise finance, procurement, project management, and business operations. TechAI enhances Oracle environments with AI-powered analytics and automation tools.
      </p>
      <p class="mt-4 text-gray-300 leading-relaxed">
        Our Oracle AI solutions include automated expense classification, predictive financial forecasting, intelligent procurement analysis, AI-powered fraud detection, and automated document processing.
      </p>
      <p class="mt-4 text-gray-300 leading-relaxed">
        We also develop conversational AI assistants that enable users to interact with Oracle ERP systems through natural language queries, improving productivity and simplifying complex workflows.
      </p>
      </div>
    </aside>
    </div>
  </section>

  <!-- 🚀 Call-to-Action Section -->
<section class="hidden relative py-20 px-6 md:px-20 text-center mt-20 overflow-hidden">
  <!-- glowing background ring -->
  <div class="absolute inset-0 bg-gradient-to-r from-blue-700/30 via-violet-700/20 to-blue-900/10 blur-3xl"></div>

  <div class="cta-glow relative z-10 max-w-4xl mx-auto bg-[#0e0f25]/60 backdrop-blur-md border border-blue-900/40 rounded-2xl p-10 shadow-[0_0_40px_rgba(37,99,235,0.25)]">
    <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 drop-shadow-[0_0_25px_rgba(37,99,235,0.3)]">
      Ready to transform your business with AI?
    </h2>
    <p class="text-gray-300 text-lg mb-10">
      Let our team help you innovate faster with intelligent automation and generative AI solutions.
    </p>
    <a
      href="/contact-us"
      class="btn-glow animate-glow inline-block font-semibold"
    >
      Contact Us
    </a>
  </div>
  </section>


  <!-- Section label: Join TechAI (chip) -->
  <div class="flex justify-center mt-10 mb-6">
    <div class="scroll-reveal inline-flex items-center gap-2 px-4 py-1 rounded-full border border-white/20 text-[12.9px] tracking-[0.25em] text-white/80 bg-white/5 backdrop-blur-sm" style="--reveal-delay: 0ms;">
      JOIN TECHAI
    </div>
  </div>

  <!-- Careers-like promo section (UQ.WEBAPP) -->
  <section class="px-6 md:px-0 pt-0 pb-16">
    <div class="grid md:grid-cols-[minmax(0,1fr)_minmax(0,1.2fr)] items-center gap-8 md:gap-0">
      <!-- Left copy -->
      <div class="px-0 md:pl-20 md:pr-12">
        <h2 class="scroll-reveal mt-0 text-base md:text-lg font-semibold text-white/80 tracking-[0.25em] text-center" style="--reveal-delay: 80ms;">DISCOVER YOUR FUTURE WITH US</h2>
        <div class="mt-6 border-t border-white/15"></div>
        <div class="mt-6 space-y-5 text-gray-300 text-base md:text-lg leading-relaxed">
          <p>
            Welcome to Tech AI, where we are revolutionizing the way businesses operate through cutting‑edge
            technologies and innovation. We are seeking ambitious and motivated employees who are passionate about the
            world of artificial intelligence and eager to learn from industry experts.
          </p>
          <p>
            As an employee at our company, you will have the opportunity to work on real‑world projects alongside our
            experienced team of data scientists, engineers, and designers. You will gain hands‑on experience in
            developing and implementing AI solutions using the latest tools and techniques.
          </p>
        </div>
        <div class="mt-8 flex items-center gap-5">
          <a href="/careers#open-positions" data-no-spa class="text-gray-300 hover:text-white underline underline-offset-4 decoration-white/30 hover:decoration-white/70 transition">
            Explore Roles
          </a>
          <a href="/contact-us" class="text-gray-300 hover:text-white underline underline-offset-4 decoration-white/30 hover:decoration-white/70 transition">
            Contact HR
          </a>
        </div>
      </div>

      <!-- Right visual -->
      <div class="md:col-start-2">
        <div class="overflow-hidden rounded-2xl md:rounded-l-2xl md:rounded-r-none border border-white/10 md:border-r-0 shadow-[0_20px_60px_rgba(0,0,0,0.35)]">
          <img src="/uq.webp" alt="Join TechAI — Discover Your Future With Us" class="w-full h-[300px] md:h-[520px] object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Section label: App Services (chip) -->
  <div class="flex justify-center mt-10 mb-8">
    <div class="scroll-reveal inline-flex items-center gap-2 px-4 py-1 rounded-full border border-white/20 text-[12.9px] tracking-[0.25em] text-white/80 bg-white/5 backdrop-blur-sm" style="--reveal-delay: 0ms;">
      OUR APP SERVICES
    </div>
  </div>

  <!-- Horizontal tile: Travel & Transportation (video) -->
  <section class="mt-2 mb-0 px-0 md:px-0">
    <div class="ai-tiles">
      <div class="scroll-reveal tile tile--square p-0 overflow-hidden relative contain-poster" style="--reveal-delay: 90ms;">
        <VideoHero
          src="/TECHAI_av.mp4"
          heightClass="h-[420px] md:h-[720px]"
          poster="/travel.png"
          />
      </div>
    </div>
  </section>

  
  </div>

<style>
  .typewriter-line {
    display: inline-block;
    white-space: nowrap;
  }

  .typewriter-line.typing-caret::after {
    content: "";
    display: inline-block;
    width: 0.08em;
    height: 0.95em;
    margin-left: 0.12em;
    background: #60a5fa;
    vertical-align: -0.1em;
    animation: hero-caret-blink 0.9s steps(1, end) infinite;
  }

  @keyframes hero-caret-blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .typewriter-line::after {
      animation: none;
      opacity: 0;
    }
  }

  .hero-reveal {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 460ms ease-out, transform 460ms ease-out;
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  .hero-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .scroll-reveal {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 460ms ease-out, transform 460ms ease-out;
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  .scroll-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .service-carousel-item {
    opacity: 0;
    transform: translateX(-20px) translateY(10px) scale(0.95);
    filter: saturate(0.88);
    transition: opacity 520ms ease, transform 520ms cubic-bezier(.2,.8,.2,1), box-shadow 520ms ease, filter 520ms ease, border-color 520ms ease;
  }

  .service-carousel-item.is-current {
    opacity: 1;
    transform: translateX(24px) translateY(-4px) scale(1.02);
    filter: saturate(1.08);
    border-color: rgba(59, 130, 246, 0.55);
    box-shadow: 0 20px 64px rgba(37, 99, 235, 0.34), 0 0 0 1px rgba(147, 197, 253, 0.22);
  }

  .ai-tiles-deck {
    position: relative;
    max-width: 400px;
    height: 520px;
    margin: 0;
  }

  .services-content {
    display: grid;
    grid-template-columns: minmax(0, 420px) minmax(0, 1fr);
    align-items: stretch;
    gap: 2.5rem;
  }

  .service-info-box {
    border: 1px solid rgba(59, 130, 246, 0.26);
    border-radius: 0.9rem;
    background: linear-gradient(145deg, rgba(14, 15, 37, 0.92), rgba(8, 12, 31, 0.9));
    box-shadow: 0 20px 56px rgba(8, 47, 122, 0.28);
    padding: 1.4rem 1.45rem;
    height: 530px;
    overflow: hidden;
  }

  .service-info-scroll {
    height: 100%;
    overflow-y: auto;
    padding-right: 0.2rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .service-info-scroll::-webkit-scrollbar {
    display: none;
  }

  .ai-tiles-deck .service-carousel-item {
    position: absolute;
    inset: 0;
    min-height: 510px !important;
    z-index: 1;
    pointer-events: none;
  }

  .ai-tiles-deck .service-carousel-item[data-pos="0"] {
    opacity: 1;
    transform: translateX(22px) translateY(-2px) scale(1.02);
    z-index: 5;
    pointer-events: auto;
  }

  .ai-tiles-deck .service-carousel-item[data-pos="1"] {
    opacity: 0.82;
    transform: translateX(0px) translateY(0px) scale(0.99);
    z-index: 4;
  }

  .ai-tiles-deck .service-carousel-item[data-pos="2"] {
    opacity: 0.68;
    transform: translateX(-18px) translateY(6px) scale(0.97);
    z-index: 3;
  }

  .ai-tiles-deck .service-carousel-item[data-pos="3"] {
    opacity: 0.5;
    transform: translateX(-30px) translateY(12px) scale(0.95);
    z-index: 2;
  }

  .services-next-btn {
    position: absolute;
    right: -22px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 44px;
    height: 44px;
    border-radius: 9999px;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: rgba(2, 6, 23, 0.72);
    color: #e2e8f0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1;
    transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease;
  }

  .services-next-btn::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 9999px;
    background: conic-gradient(from 90deg at 50% 50%, rgba(59,130,246,0.5), rgba(124,58,237,0.5), rgba(236,72,153,0.35), rgba(59,130,246,0.5));
    filter: blur(16px);
    opacity: 0;
    pointer-events: none;
    transition: opacity .2s ease;
  }

  .services-next-btn:hover,
  .ai-tiles-deck:hover .services-next-btn {
    transform: translateY(-50%) translateX(2px) translateY(-2px);
    border-color: rgba(96, 165, 250, 0.65);
    background: rgba(15, 23, 42, 0.88);
    box-shadow: 0 12px 34px rgba(37, 99, 235, 0.28);
  }

  .services-next-btn:hover::before,
  .ai-tiles-deck:hover .services-next-btn::before {
    opacity: .85;
  }

  .ai-tiles-deck .tile:hover {
    transform: inherit !important;
  }

  .ai-tiles-deck .tile:hover::before {
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .services-content {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .ai-tiles-deck {
      max-width: 100%;
      height: 460px;
    }
    .service-info-box {
      height: 470px;
      padding: 1.1rem 1rem;
    }
    .ai-tiles-deck .service-carousel-item {
      min-height: 450px !important;
    }
    .ai-tiles-deck .service-carousel-item[data-pos="0"] {
      transform: translateX(10px) translateY(-1px) scale(1.01);
    }
    .ai-tiles-deck .service-carousel-item[data-pos="1"] {
      transform: translateX(-2px) translateY(2px) scale(0.985);
    }
    .ai-tiles-deck .service-carousel-item[data-pos="2"] {
      transform: translateX(-12px) translateY(6px) scale(0.97);
    }
    .ai-tiles-deck .service-carousel-item[data-pos="3"] {
      transform: translateX(-20px) translateY(10px) scale(0.955);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .scroll-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .service-carousel-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .ai-tiles-deck {
      height: auto;
      max-width: none;
    }
    .ai-tiles-deck .service-carousel-item {
      position: static;
      min-height: auto !important;
      pointer-events: auto;
      z-index: auto;
    }
  }
</style>

<script is:inline>
  (function () {
    const lead = document.getElementById("heroTypewriterLead");
    const accent = document.getElementById("heroTypewriterAccent");
    const bodyType = document.getElementById("heroBodyType");
    const bodySegments = Array.from(document.querySelectorAll("#heroBodyType .hero-body-seg"));
    const revealNodes = Array.from(document.querySelectorAll(".hero-reveal"));
    if (!lead || !accent || !bodyType || !bodySegments.length) return;

    const leadText = lead.dataset.text || lead.textContent || "";
    const accentText = accent.dataset.text || accent.textContent || "";
    const bodyTexts = bodySegments.map((seg) => seg.textContent || "");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (reduceMotion) {
      lead.textContent = leadText;
      accent.textContent = accentText;
      bodySegments.forEach((seg, idx) => {
        seg.textContent = bodyTexts[idx];
      });
      revealNodes.forEach((node) => node.classList.add("is-visible"));
      return;
    }

    lead.textContent = "";
    accent.textContent = "";
    bodySegments.forEach((seg) => {
      seg.textContent = "";
    });
    lead.classList.add("typing-caret");

    let i = 0;
    const typeLead = () => {
      i += 1;
      lead.textContent = leadText.slice(0, i);
      if (i < leadText.length) {
        window.setTimeout(typeLead, 85);
        return;
      }
      lead.classList.remove("typing-caret");
      accent.classList.add("typing-caret");
      window.setTimeout(typeAccent, 120);
    };

    let j = 0;
    const typeAccent = () => {
      j += 1;
      accent.textContent = accentText.slice(0, j);
      if (j < accentText.length) {
        window.setTimeout(typeAccent, 85);
        return;
      }
      accent.classList.remove("typing-caret");
      revealNodes.forEach((node) => node.classList.add("is-visible"));
      window.setTimeout(typeBodySegment, 120);
    };

    let segIdx = 0;
    let charIdx = 0;
    const typeBodySegment = () => {
      if (segIdx >= bodySegments.length) return;
      charIdx += 1;
      bodySegments[segIdx].textContent = bodyTexts[segIdx].slice(0, charIdx);
      if (charIdx < bodyTexts[segIdx].length) {
        window.setTimeout(typeBodySegment, 16);
        return;
      }
      segIdx += 1;
      charIdx = 0;
      if (segIdx < bodySegments.length) {
        window.setTimeout(typeBodySegment, 8);
      }
    };

    window.setTimeout(typeLead, 180);
  })();

  (function () {
    const footer = document.querySelector("main#app > footer");
    if (footer) {
      footer.classList.add("scroll-reveal");
      footer.style.setProperty("--reveal-delay", "120ms");
    }

    const nodes = Array.from(document.querySelectorAll(".scroll-reveal"));
    if (!nodes.length) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduceMotion) {
      nodes.forEach((node) => node.classList.add("is-visible"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.16, rootMargin: "0px 0px -8% 0px" }
    );

    const observeAll = () => nodes.forEach((node) => observer.observe(node));
    if (window.scrollY > 10) {
      observeAll();
      return;
    }

    const onFirstScroll = () => {
      if (window.scrollY <= 10) return;
      observeAll();
      window.removeEventListener("scroll", onFirstScroll);
    };

    window.addEventListener("scroll", onFirstScroll, { passive: true });
  })();

  (function () {
    const items = Array.from(document.querySelectorAll("#servicesSection .service-carousel-item"));
    const nextBtn = document.getElementById("servicesNextBtn");
    if (items.length < 2) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      items.forEach((item) => item.classList.add("is-current"));
      return;
    }

    let idx = 0;
    let timer = 0;

    const show = (next) => {
      idx = next % items.length;
      items.forEach((item, i) => {
        item.classList.toggle("is-current", i === idx);
        const pos = (i - idx + items.length) % items.length;
        item.setAttribute("data-pos", String(Math.min(pos, 3)));
      });
    };

    const tick = () => show((idx + 1) % items.length);
    const start = () => {
      if (timer) return;
      timer = window.setInterval(tick, 1900);
    };
    const stop = () => {
      if (!timer) return;
      window.clearInterval(timer);
      timer = 0;
    };

    show(0);
    start();
    items.forEach((item) => {
      item.addEventListener("mouseenter", stop);
      item.addEventListener("mouseleave", start);
      item.addEventListener("focusin", stop);
      item.addEventListener("focusout", start);
    });
    if (nextBtn instanceof HTMLButtonElement) {
      nextBtn.addEventListener("click", () => {
        stop();
        tick();
        start();
      });
    }
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop();
      else start();
    });
  })();

  (function () {
    const scrollNodes = Array.from(document.querySelectorAll(".service-info-scroll"));
    if (!scrollNodes.length) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    scrollNodes.forEach((node) => {
      let rafId = 0;
      let lastTs = 0;
      let resumeTimer = 0;
      const speedPxPerSec = 60;

      const step = (ts) => {
        if (!lastTs) lastTs = ts;
        const dt = (ts - lastTs) / 1000;
        lastTs = ts;

        const maxScroll = node.scrollHeight - node.clientHeight;
        if (maxScroll > 0) {
          node.scrollTop += speedPxPerSec * dt;
          if (node.scrollTop >= maxScroll - 1) {
            node.scrollTop = 0;
          }
        }
        rafId = window.requestAnimationFrame(step);
      };

      const start = () => {
        if (rafId) return;
        rafId = window.requestAnimationFrame(step);
      };

      const stop = () => {
        if (!rafId) return;
        window.cancelAnimationFrame(rafId);
        rafId = 0;
        lastTs = 0;
      };

      const scheduleResume = () => {
        if (resumeTimer) window.clearTimeout(resumeTimer);
        resumeTimer = window.setTimeout(start, 900);
      };

      node.addEventListener("mouseenter", stop);
      node.addEventListener("mouseleave", start);
      node.addEventListener("touchstart", stop, { passive: true });
      node.addEventListener("touchend", scheduleResume, { passive: true });
      node.addEventListener("wheel", () => {
        stop();
        scheduleResume();
      }, { passive: true });
      node.addEventListener("touchmove", () => {
        stop();
        scheduleResume();
      }, { passive: true });
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) stop();
        else start();
      });

      window.setTimeout(start, 450);
    });
  })();
</script>

</BaseLayout>
 
